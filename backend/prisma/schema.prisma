// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   // ADMIN, SALES, PURCHASE, MFG, INVENTORY, OWNER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  AuditLog  AuditLog[]
  SalesOrder SalesOrder[]
  ManufacturingOrder ManufacturingOrder[] @relation("UserToMO")
  PurchaseOrder PurchaseOrder[] @relation("ResponsiblePerson")
  PurchaseOrderComment PurchaseOrderComment[]
}

model Vendor {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  products  Product[]
  purchaseOrders PurchaseOrder[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(uuid())
  name            String
  salesPrice      Float
  costPrice       Float
  qtyOnHand       Float    @default(0)
  qtyReserved     Float    @default(0)
  procurementType String   // MTS, MTO
  supplyMethod    String   // MANUFACTURE, PURCHASE
  vendorId        String?
  vendor          Vendor?  @relation(fields: [vendorId], references: [id])
  bomId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  SalesOrderLine    SalesOrderLine[]
  PurchaseOrderLine PurchaseOrderLine[]
  BoM               BoM?                @relation("ProductToBoM")
  BoMLine           BoMLine[]
  ManufacturingOrder ManufacturingOrder[]
  StockLedger       StockLedger[]
  MOComponent       MOComponent[]
}

model SalesOrder {
  id              String           @id @default(uuid())
  customerName    String
  customerAddress String?
  salesPersonId   String?
  salesPerson     User?            @relation(fields: [salesPersonId], references: [id])
  status          String           // DRAFT, CONFIRMED, PARTIALLY_DELIVERED, DELIVERED, CANCELLED
  totalAmount     Float
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orderLines      SalesOrderLine[]
}

model SalesOrderLine {
  id           String     @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Float
  deliveredQty Float      @default(0)
  price        Float
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id                  String                 @id @default(uuid())
  vendorId            String?
  vendor              Vendor?                @relation(fields: [vendorId], references: [id])
  vendorName          String                 // Fallback/Legacy
  vendorAddress       String?
  responsiblePersonId String?
  responsiblePerson   User?                  @relation("ResponsiblePerson", fields: [responsiblePersonId], references: [id])
  status              String                 // DRAFT, NEGOTIATION, CONFIRMED, PARTIALLY_RECEIVED, FULLY_RECEIVED, CANCELLED
  totalAmount         Float
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  orderLines          PurchaseOrderLine[]
  comments            PurchaseOrderComment[]
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  receivedQty     Float         @default(0)
  price           Float
  initialPrice    Float         @default(0) // Price at the time of order creation
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
}

model PurchaseOrderComment {
  id              String        @id @default(uuid())
  purchaseOrderId String
  userId          String
  text            String
  createdAt       DateTime      @default(now())
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
}

model BoM {
  id         String    @id @default(uuid())
  productId  String    @unique
  name       String
  product    Product   @relation("ProductToBoM", fields: [productId], references: [id])
  bomLines   BoMLine[]
  operations Operation[]
  ManufacturingOrder ManufacturingOrder[]
}

model BoMLine {
  id          String  @id @default(uuid())
  bomId       String
  componentId String
  quantity    Float
  bom         BoM     @relation(fields: [bomId], references: [id])
  component   Product @relation(fields: [componentId], references: [id])
}

model WorkCenter {
  id         String      @id @default(uuid())
  name       String
  Operations Operation[]
  WorkOrders WorkOrder[]
}

model Operation {
  id           String      @id @default(uuid())
  name         String
  duration     Int         // in minutes
  workCenterId String
  bomId        String?
  bom          BoM?        @relation(fields: [bomId], references: [id])
  workCenter   WorkCenter  @relation(fields: [workCenterId], references: [id])
  WorkOrders   WorkOrder[]
}

model ManufacturingOrder {
  id          String      @id @default(uuid())
  productId   String
  quantity    Float
  status      String      // DRAFT, CONFIRMED, IN_PROGRESS, DONE, CANCELLED
  bomId       String
  assigneeId  String?
  assignee    User?       @relation("UserToMO", fields: [assigneeId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product     @relation(fields: [productId], references: [id])
  bom         BoM         @relation(fields: [bomId], references: [id])
  WorkOrders  WorkOrder[]
  components  MOComponent[]
}

model MOComponent {
  id          String    @id @default(uuid())
  moId        String
  productId   String
  toConsume   Float
  consumed    Float     @default(0)
  mo          ManufacturingOrder @relation(fields: [moId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
}

model WorkOrder {
  id               String             @id @default(uuid())
  moId             String
  operationId      String?
  operationName    String?            // Fallback for custom operations
  workCenterId     String?
  status           String             // PENDING, IN_PROGRESS, DONE
  expectedDuration Int                @default(0) // in minutes
  realDuration     Int                @default(0)
  mo               ManufacturingOrder @relation(fields: [moId], references: [id])
  operation        Operation?         @relation(fields: [operationId], references: [id])
  workCenter       WorkCenter?        @relation(fields: [workCenterId], references: [id])
}

model StockLedger {
  id             String   @id @default(uuid())
  productId      String
  quantityChange Float
  type           String   // SALE, PURCHASE, MFG_CONSUME, MFG_PRODUCE
  referenceId    String
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model AccessRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String
  message   String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}
