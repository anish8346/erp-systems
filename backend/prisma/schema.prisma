// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   // ADMIN, SALES, PURCHASE, MFG, INVENTORY, OWNER
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  AuditLog  AuditLog[]
}

model Product {
  id              String   @id @default(uuid())
  name            String
  salesPrice      Float
  costPrice       Float
  qtyOnHand       Float    @default(0)
  qtyReserved     Float    @default(0)
  procurementType String   // MTS, MTO
  supplyMethod    String   // MANUFACTURE, PURCHASE
  vendorId        String?
  bomId           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  SalesOrderLine    SalesOrderLine[]
  PurchaseOrderLine PurchaseOrderLine[]
  BoM               BoM?                @relation("ProductToBoM")
  BoMLine           BoMLine[]
  ManufacturingOrder ManufacturingOrder[]
  StockLedger       StockLedger[]
}

model SalesOrder {
  id           String           @id @default(uuid())
  customerName String
  status       String           // DRAFT, CONFIRMED, DELIVERED, CANCELLED
  totalAmount  Float
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  orderLines   SalesOrderLine[]
}

model SalesOrderLine {
  id           String     @id @default(uuid())
  salesOrderId String
  productId    String
  quantity     Float
  price        Float
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id])
  product      Product    @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  vendorName   String
  status       String              // DRAFT, CONFIRMED, RECEIVED
  totalAmount  Float
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  orderLines   PurchaseOrderLine[]
}

model PurchaseOrderLine {
  id              String        @id @default(uuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  price           Float
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  product         Product       @relation(fields: [productId], references: [id])
}

model BoM {
  id         String    @id @default(uuid())
  productId  String    @unique
  name       String
  product    Product   @relation("ProductToBoM", fields: [productId], references: [id])
  bomLines   BoMLine[]
  ManufacturingOrder ManufacturingOrder[]
}

model BoMLine {
  id          String  @id @default(uuid())
  bomId       String
  componentId String
  quantity    Float
  bom         BoM     @relation(fields: [bomId], references: [id])
  component   Product @relation(fields: [componentId], references: [id])
}

model WorkCenter {
  id         String      @id @default(uuid())
  name       String
  Operations Operation[]
}

model Operation {
  id           String      @id @default(uuid())
  name         String
  duration     Int         // in minutes
  workCenterId String
  workCenter   WorkCenter  @relation(fields: [workCenterId], references: [id])
  WorkOrders   WorkOrder[]
}

model ManufacturingOrder {
  id          String      @id @default(uuid())
  productId   String
  quantity    Float
  status      String      // DRAFT, CONFIRMED, IN_PROGRESS, DONE
  bomId       String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product     @relation(fields: [productId], references: [id])
  bom         BoM         @relation(fields: [bomId], references: [id])
  WorkOrders  WorkOrder[]
}

model WorkOrder {
  id          String             @id @default(uuid())
  moId        String
  operationId String
  status      String             // PENDING, IN_PROGRESS, DONE
  duration    Int
  mo          ManufacturingOrder @relation(fields: [moId], references: [id])
  operation   Operation          @relation(fields: [operationId], references: [id])
}

model StockLedger {
  id             String   @id @default(uuid())
  productId      String
  quantityChange Float
  type           String   // SALE, PURCHASE, MFG_CONSUME, MFG_PRODUCE
  referenceId    String
  createdAt      DateTime @default(now())
  product        Product  @relation(fields: [productId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model AccessRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String
  message   String
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt DateTime @default(now())
}
